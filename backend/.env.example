# LLM Provider: "openai", "anthropic", or "google"
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o

# Provider API Keys (only the key for your chosen provider is required)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Common model names per provider:
#   openai:    gpt-4o, gpt-4o-mini, gpt-4-turbo
#   anthropic: claude-sonnet-4-20250514, claude-haiku-4-20250414
#   google:    gemini-2.0-flash, gemini-2.5-pro

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API Config Directory (defaults to ./api_configs)
# API_CONFIG_DIR=./api_configs

# User Config Directory (defaults to ./user_api_configs)
# USER_CONFIG_DIR=./user_api_configs

# MCP Server URL (SSE endpoint, defaults to http://localhost:8001/sse)
# MCP_SERVER_URL=http://localhost:8001/sse

# MCP Server Port (defaults to 8001)
# MCP_PORT=8001

# Add your API-specific environment variables below.
# These can be referenced in YAML configs as ${VAR_NAME}
# Example:
# MY_API_TOKEN=your-api-token
